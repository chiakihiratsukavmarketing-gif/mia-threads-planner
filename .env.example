# Threads API（証券ウーマン「みあ」アカウント）
THREADS_USER_ID=your_threads_user_id
THREADS_ACCESS_TOKEN=your_long_lived_access_token

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key

# 設定
DRY_RUN=true          # trueにすると実際に投稿せずログだけ出す
MAX_POSTS_PER_DAY=3   # 1日の最大投稿数（アカバン対策）
POST_DELAY_SECONDS=60 # 連続投稿時の待機秒数
